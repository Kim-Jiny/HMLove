<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Top bar: couple name + D-Day -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/cal_couple_names"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E91E63"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:id="@+id/cal_dday_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#C2185B"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:id="@+id/cal_settings_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="⚙"
            android:textColor="#9E9E9E"
            android:textSize="14sp"
            android:background="@drawable/widget_calendar_nav_btn_bg" />
    </LinearLayout>

    <!-- Month header: prev / title / today / next -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/cal_prev_month"
            android:layout_width="28dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="◀"
            android:textColor="#E91E63"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/widget_calendar_nav_btn_bg" />

        <TextView
            android:id="@+id/cal_month_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#424242"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/cal_today_month"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="오늘"
            android:textColor="#E91E63"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:background="@drawable/widget_calendar_nav_btn_bg" />

        <TextView
            android:id="@+id/cal_next_month"
            android:layout_width="28dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="▶"
            android:textColor="#E91E63"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_calendar_nav_btn_bg" />
    </LinearLayout>

    <!-- Weekday headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="일"
            android:textColor="#E91E63"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="월"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="화"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="수"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="목"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="금"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="토"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Calendar grid: 6 rows x 7 columns = 42 cells -->
    <!-- Each cell is a vertical LinearLayout with day number + dot indicator -->
    <LinearLayout
        android:id="@+id/cal_grid_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row 0 -->
        <LinearLayout
            android:id="@+id/cal_row_0"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal" />

        <!-- Row 1 -->
        <LinearLayout
            android:id="@+id/cal_row_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal" />

        <!-- Row 2 -->
        <LinearLayout
            android:id="@+id/cal_row_2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal" />

        <!-- Row 3 -->
        <LinearLayout
            android:id="@+id/cal_row_3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal" />

        <!-- Row 4 -->
        <LinearLayout
            android:id="@+id/cal_row_4"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal" />

        <!-- Row 5 -->
        <LinearLayout
            android:id="@+id/cal_row_5"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal" />
    </LinearLayout>

</LinearLayout>
