<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="캘린더 위젯 설정"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#E0E0E0" />

        <!-- 배경 색상 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="배경 색상"
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold" />

        <GridLayout
            android:id="@+id/swatch_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="6dp"
            android:background="@drawable/widget_settings_swatch_panel_bg"
            android:columnCount="6"
            android:alignmentMode="alignMargins">

            <View
                android:id="@+id/swatch_0"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_1"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_2"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_3"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_4"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_5"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_6"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_7"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_8"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_9"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_10"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
            <View
                android:id="@+id/swatch_11"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp" />
        </GridLayout>

        <!-- 투명도 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="투명도"
                android:textColor="#424242"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/alpha_value_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="#E91E63"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/alpha_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:max="255" />

        <!-- 미리보기 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="미리보기"
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/widget_settings_checker_bg">

            <View
                android:id="@+id/preview_box"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="6dp" />
        </FrameLayout>

        <!-- 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기본값"
                android:textColor="#757575"
                android:background="@android:color/transparent" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="취소"
                android:textColor="#757575"
                android:background="@android:color/transparent" />

            <Button
                android:id="@+id/btn_apply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="적용"
                android:textColor="#FFFFFF"
                android:background="@drawable/widget_settings_apply_btn_bg"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
