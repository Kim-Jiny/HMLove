# === PostgreSQL ===
DB_PASSWORD=여기에_강력한_비밀번호_입력

# === MinIO (S3 호환 스토리지) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=여기에_강력한_비밀번호_입력

# === Storage Public URL ===
# Nginx를 통한 공개 URL (도메인 설정 후 변경)
# 예: https://yourdomain.com/storage
STORAGE_PUBLIC_URL=http://서버IP/storage

# === JWT ===
JWT_SECRET=여기에_랜덤_시크릿_입력
JWT_REFRESH_SECRET=여기에_랜덤_시크릿_입력

# === Anthropic (Fortune AI) ===
ANTHROPIC_API_KEY=sk-ant-xxx

# === Admin ===
ADMIN_PASSWORD=여기에_관리자_비밀번호_입력

# === Naver Maps (NCP) ===
NCP_MAP_CLIENT_ID=
NCP_MAP_CLIENT_SECRET=
