# 로컬 dev 전용 — `cp .env.local.example .env.local` 후 본인 값으로 수정.
# .env.local 은 .gitignore 되어있고, src/index.js 가 NODE_ENV=production 이 아닐 때 먼저 로드함.
# 여기서 정의한 키는 .env 보다 우선.

# === 서버 ===
PORT=4000

# === 로컬 Postgres (네이티브로 띄운 경우) ===
# Mac 에서 brew services start postgresql 등으로 띄운 DB 기준 예시.
# 본인 로컬 계정/비번/DB명에 맞춰 수정.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hmlove?sslmode=disable

# === 스토리지 ===
# STORAGE_MODE=local 이면 MinIO 없이 서버의 ./uploads 폴더에 직접 저장하고
# 클라이언트는 서버의 /uploads/<key> 경로로 가져간다. (위젯·앱이 같은 LAN IP 사용)
# STORAGE_PUBLIC_URL 을 비워두면 서버가 자동으로 LAN IP를 잡아서 ${IP}:${PORT} 로 폴백.
STORAGE_MODE=local
# STORAGE_PUBLIC_URL=http://192.168.0.5:4000   # 자동탐지 안 되거나 강제 지정하고 싶을 때만

# === (선택) MinIO 모드로 돌리고 싶으면 STORAGE_MODE 지우고 아래 채우기 ===
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=hmlove
# STORAGE_PUBLIC_URL=http://localhost:9000

# === JWT (.env 에 있는 값 재사용해도 됨) ===
JWT_SECRET=local-dev-jwt-secret-change-me
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-me

# === Firebase (푸시 끄려면 비워두면 됨; 비어있으면 admin SDK가 default credential 시도) ===
# FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
